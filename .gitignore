/print-*.pdf

# User-uploaded sample data (now persisted on Render disk — not needed in git).
# Tracked seed DXFs (1階/2階床スリーブ図.dxf) are unaffected since gitignore
# never untracks files already in git.
/dxf_output/*.dxf
/dxf_output/*.json
/ifc_output/
/*.ifc
